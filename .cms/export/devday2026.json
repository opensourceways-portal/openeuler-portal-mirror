    {
      "id": 1,
      "documentId": "Eu0KOKVksppFeG5wHfBSv",
      "floor": {
        "title": "活动简介",
        "id": "introduction",
        "description": [
          "openEuler Developer Day 2026（ODD 2026）是开放原子开源基金会孵化及运营的 openEuler 社区发起的年度开发者大会。\n在 AI、算力与多样性架构全面加速的时代，操作系统正跃升为技术创新核心引擎与生态基石。大会聚焦 AI 时代操作系统创新，展示社区最新AI技术成果与行业实践，SIG Gathering上围绕未来 LTS 及创新版本规划凝聚技术共识，协同版本路线与联合创新。",
          "秉承 “我参与，我做主” 的开源精神，openEuler Developer Day 2026 欢迎广大开发者共同参与，共创属于开发者的 openEuler 时代。"
        ]
      },
      "createdAt": "2026-04-14T03:25:41.416Z",
      "updatedAt": "2026-04-15T07:26:48.251Z",
      "publishedAt": "2026-04-14T03:25:43.359Z",
      "locale": "zh"
    },
    {
      "id": 2,
      "documentId": "v9zrTzTmROOmfxOLVaJtx",
      "floor": {
        "title": "SIG Gathering",
        "id": "SIG-Gathering",
        "card_list": [
          {
            "title": "AI生态支持&技术创新",
            "description": [
              "openEuler 作为基础设施中间层，面向通用算力与智能算力多样化进行使能。本专题聚焦 AI 生态工具的适配集成与 AI Infra 技术创新，共同构建开放、高效的 AI 基础软件栈。"
            ],
            "label": "查看议题",
            "url": "https://etherpad.openeuler.org/p/ODD26-SIG-AIEco",
            "address": "多功能厅1",
            "time": "全天"
          },
          {
            "title": "Kernel&基础服务",
            "description": [
              "本专题聚焦 openEuler 内核及周边基础库，围绕竞争力与稳定性提升、上游社区贡献、CVE 高效响应、多样性算力平台支持 四大方向展开深入探讨，旨在持续提升内核的健壮性、安全性与生态适配能力，为上层应用提供坚实底座。"
            ],
            "label": "查看议题",
            "url": "https://etherpad.openeuler.org/p/ODD26-SIG-Kernel",
            "address": "多功能厅2",
            "time": "全天"
          },
          {
            "title": "RISC-V",
            "description": [
              "探讨 openEuler 在 RISC-V 架构上的最新进展、应用案例与发展方向，持续提升多样性算力支持能力，推动 RISC-V 生态繁荣。"
            ],
            "label": "查看议题",
            "url": "https://etherpad.openeuler.org/p/ODD26-SIG-RISC-V",
            "address": "多功能厅5",
            "time": "上午"
          },
          {
            "title": "超节点技术创新",
            "description": [
              "面向超节点场景，聚焦硬件使能、中间件与应用创新，围绕内存统一编址、设备池化管理、异构资源融合、全局资源视图等技术特点，充分释放超节点算力潜能。"
            ],
            "label": "查看议题",
            "url": "https://etherpad.openeuler.org/p/ODD26-SIG-SuperNode",
            "address": "多功能厅6",
            "time": "上午"
          },
          {
            "title": "全场景&Agent Infra",
            "description": [
              "探讨openEuler在云原生、大数据、数据库等领域的技术生态满足度提升、技术创新、领域Top开源社区集成和联合创新等相关内容，为全场景领域开发者和用户提供极致体验；探索AI Agent时代的安全沙箱等技术创新，打造可靠的Agent基础设施。"
            ],
            "address": "多功能厅7 + 8",
            "time": "上午",
            "label": "查看议题",
            "url": "https://etherpad.openeuler.org/p/ODD26-SIG-CloudNativeAgent"
          },
          {
            "title": "AI时代高效开发与生态包管理",
            "description": [
              "面向 AI 时代开发者，围绕社区基础设施、构建测试服务、工具链，优化“基于 openEuler 做开发”的体验，并探讨软件包管理流程与技术改进。"
            ],
            "address": "多功能厅5",
            "time": "下午",
            "url": "https://etherpad.openeuler.org/p/ODD26-SIG-DevPackage",
            "label": "查看议题"
          },
          {
            "title": "AI使能安全与漏洞处理",
            "description": [
              "围绕 openEuler 社区安全技术与流程，探讨 CVE 修复的工具链、最佳实践，以及 AI 技术在漏洞感知、分析与修复中的应用。"
            ],
            "address": "多功能厅6",
            "time": "下午",
            "label": "查看议题",
            "url": "https://etherpad.openeuler.org/p/ODD26-SIG-AISecurity"
          },
          {
            "title": "具身智能&嵌入式",
            "description": [
              "面向新型工业自动化与具身智能场景，聚焦嵌入式核心技术（MICA、UniProton、嵌入式虚拟化）的演进，探索实时性与智能化融合的技术创新。"
            ],
            "address": "多功能厅7 + 8",
            "time": "下午",
            "label": "查看议题",
            "url": "https://etherpad.openeuler.org/p/ODD26-SIG-Embedded"
          }
        ]
      },
